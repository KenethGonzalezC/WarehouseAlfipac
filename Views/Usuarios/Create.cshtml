@using AWESOME.Models.ViewModels
@model UsuarioCreateViewModel

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="mb-4">

    <h2 class="fw-bold mb-1">
        Crear Usuario
    </h2>

    <p class="text-muted mb-0">
        Crear un nuevo acceso compartido con SCL.
    </p>

</div>

<div class="card shadow-sm">

    <div class="card-body p-4">

        <form asp-action="Create"
              method="post"
              autocomplete="off">

            @Html.AntiForgeryToken()

            <div class="row g-4">

                <div class="col-md-6">

                    <label asp-for="NombreUsuario"
                           class="form-label">
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-person"></i>
                        </span>

                        <input asp-for="NombreUsuario"
                               class="form-control"
                               autocomplete="new-username" />

                    </div>

                    <span asp-validation-for="NombreUsuario"
                          class="text-danger small">
                    </span>

                </div>

                <div class="col-md-6">

                    <label asp-for="Password"
                           class="form-label">
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-lock"></i>
                        </span>

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               autocomplete="new-password" />

                    </div>

                    <span asp-validation-for="Password"
                          class="text-danger small">
                    </span>

                </div>

                <div class="col-md-6">

                    <label asp-for="Rol"
                           class="form-label">
                        Rol
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-shield-lock"></i>
                        </span>

                        <select asp-for="Rol"
                                asp-items="Model.RolesDisponibles"
                                class="form-select">

                            <option value="">
                                Seleccione un rol
                            </option>

                        </select>

                    </div>

                    <span asp-validation-for="Rol"
                          class="text-danger small">
                    </span>

                </div>

            </div>

            <div class="mt-4 d-flex justify-content-between">

                <a asp-action="Index"
                   class="btn btn-outline-secondary">

                    <i class="bi bi-arrow-left"></i>
                    Cancelar

                </a>

                <button type="submit"
                        class="btn btn-primary">

                    <i class="bi bi-floppy"></i>
                    Crear Usuario

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}