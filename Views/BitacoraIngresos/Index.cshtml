@model AWESOME.Models.ViewModels.IngresosIndexViewModel

@{
    ViewData["Title"] = "Ingresos - Control Tower";
}

<div class="container-fluid awesome-ingresos">

    <!-- HEADER KPI -->
    <div class="row g-3 mb-4">

        <!-- TOTAL DEL DÍA -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h6 class="text-muted mb-1">Ingresos del día</h6>
                            <h3 class="mb-0 fw-bold">
                                @Model.TotalIngresos
                            </h3>
                        </div>

                        <div class="icon-box bg-success-subtle text-success">
                            <i class="bi bi-arrow-down-circle"></i>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- FECHA SELECCIONADA -->
        <div class="col-md-8">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <form method="get" class="d-flex align-items-end gap-3 flex-wrap">

                        <div>

                            <label class="form-label small text-muted">
                                Fecha de consulta
                            </label>

                            <input type="date"
                                   name="fecha"
                                   value="@Model.FechaSeleccionada.ToString("yyyy-MM-dd")"
                                   class="form-control" />

                        </div>

                        <div>

                            <button class="btn btn-primary">
                                <i class="bi bi-search"></i>
                                Consultar
                            </button>

                        </div>

                        <div class="text-muted small ms-auto">
                            <i class="bi bi-clock"></i>
                            Última actualización: @DateTime.Now.ToString("HH:mm")
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

    <!-- TABLA CONTROL TOWER -->
    <div class="card border-0 shadow-sm">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">

            <div>
                <h6 class="mb-0 fw-semibold">
                    Lista de contenedores ingresados
                </h6>
                <small class="text-muted">
                    Vista operativa en tiempo real desde SCL
                </small>
            </div>

            <span class="badge bg-dark">
                @Model.Ingresos.Count registros
            </span>

        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>Hora</th>
                            <th>Contenedor</th>  
                            <th>Marchamos</th>
                            <th>Cliente</th>                                                       
                            <th>Viaje / DUA</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.Ingresos)
                        {
                            <tr>
                                <td>
                                    @item.FechaHoraIngreso.ToString("HH:mm")
                                </td>

                                <td class="fw-bold">
                                    @item.Contenedor
                                </td>                                

                                <td>
                                    @item.Marchamos
                                </td>

                                <td>
                                    @item.Cliente
                                </td>                                                             

                                <td>
                                    @item.ViajeDua
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<style>
    .awesome-ingresos .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .awesome-ingresos table tbody tr:hover {
        background: #f8fafc;
    }

    .awesome-ingresos table td {
        font-size: 14px;
        white-space: nowrap;
    }

    .awesome-ingresos .table-responsive {
        max-height: 65vh;
        overflow-y: auto;
    }
</style>