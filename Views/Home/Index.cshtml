@{
    ViewData["Title"] = "AWESOME - Panel Operativo";
}

<div class="awesome-home">

    <!-- HERO HEADER -->
    <div class="awesome-hero mb-4">

        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">

            <div>

                <h1 class="fw-bold mb-1">
                    AWESOME
                </h1>

                <p class="text-muted mb-0">
                    Warehouse System Manager · Control operativo en tiempo real
                </p>

            </div>

            <div class="text-muted small">
                <i class="bi bi-shield-check"></i>
                Sistema activo
            </div>

        </div>

    </div>

    <!-- MAIN MODULES -->
    <div class="row g-4">

        <!-- INGRESOS -->
        <div class="col-md-6 col-lg-3">

            <a asp-controller="BitacoraIngresos" asp-action="Index" class="awesome-link">

                <div class="card awesome-card h-100 border-0 shadow-sm">

                    <div class="card-body">

                        <div class="awesome-card-header">

                            <div class="icon-box bg-success-subtle text-success">
                                <i class="bi bi-arrow-down-circle"></i>
                            </div>

                            <div>
                                <h5 class="mb-0">Ingresos</h5>
                                <small class="text-muted">Contenedores que entran</small>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- DESPACHOS -->
        <div class="col-md-6 col-lg-3">

            <a asp-controller="BitacoraDespachos" asp-action="Index" class="awesome-link">

                <div class="card awesome-card h-100 border-0 shadow-sm">

                    <div class="card-body">

                        <div class="awesome-card-header">

                            <div class="icon-box bg-danger-subtle text-danger">
                                <i class="bi bi-arrow-up-circle"></i>
                            </div>

                            <div>
                                <h5 class="mb-0">Despachos</h5>
                                <small class="text-muted">Salidas del warehouse</small>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- BITÁCORA -->
        <div class="col-md-6 col-lg-3">

            <a asp-controller="Bitacora" asp-action="Index" class="awesome-link">

                <div class="card awesome-card h-100 border-0 shadow-sm">

                    <div class="card-body">

                        <div class="awesome-card-header">

                            <div class="icon-box bg-primary-subtle text-primary">
                                <i class="bi bi-journal-text"></i>
                            </div>

                            <div>
                                <h5 class="mb-0">Bitácora diaria</h5>
                                <small class="text-muted">Registro operativo completo</small>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- USUARIOS -->
        @if (User.IsInRole("Administrador"))
        {
            <div class="col-md-6 col-lg-3">

                <a asp-controller="Usuarios" asp-action="Index" class="awesome-link">

                    <div class="card awesome-card h-100 border-danger shadow-sm">

                        <div class="card-body">

                            <div class="awesome-card-header">

                                <div class="icon-box bg-danger-subtle text-danger">
                                    <i class="bi bi-people"></i>
                                </div>

                                <div>
                                    <h5 class="mb-0">Usuarios</h5>
                                    <small class="text-muted">Control de accesos</small>
                                </div>

                            </div>

                        </div>

                    </div>

                </a>

            </div>
        }

    </div>

    <!-- FOOTER INFO PANEL -->
    <div class="mt-5">

        <div class="card border-0 shadow-sm">

            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">

                <div class="text-muted small">
                    <i class="bi bi-info-circle"></i>
                    Módulos operativos principales del sistema AWESOME
                </div>
                                
            </div>

        </div>

    </div>

</div>